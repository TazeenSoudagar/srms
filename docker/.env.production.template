# ==============================================
# SRMS Production Environment Configuration
# ==============================================
# Copy this file to:
#   - docker/.env.backend (for Laravel backend)
#   - docker/.env.customer (for Next.js customer app)
# Generate secure values for all secrets!
# ==============================================

# ---------------------------------------------
# Application Settings
# ---------------------------------------------
APP_NAME="SRMS"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_URL=https://yourdomain.com

# ---------------------------------------------
# Domain Configuration
# ---------------------------------------------
DOMAIN=yourdomain.com

# ---------------------------------------------
# Database Configuration
# ---------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=srms_backend
DB_USERNAME=srms_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_HERE

# ---------------------------------------------
# Redis Configuration
# ---------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ---------------------------------------------
# Queue & Cache Configuration
# ---------------------------------------------
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ---------------------------------------------
# Mail Configuration
# ---------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------
# Sanctum Configuration
# ---------------------------------------------
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com

# ---------------------------------------------
# Frontend URLs
# ---------------------------------------------
FRONTEND_URL=https://yourdomain.com/app
CUSTOMER_URL=https://yourdomain.com

# ---------------------------------------------
# Hashids Configuration
# ---------------------------------------------
# Generate a random 32-character string and KEEP IT CONSISTENT
HASHIDS_SALT=CHANGE_ME_RANDOM_32_CHAR_STRING_HERE
HASHIDS_LENGTH=8

# ---------------------------------------------
# OTP Configuration
# ---------------------------------------------
ADMIN_BYPASS_OTP=false
OTP_EXPIRES_IN_MINUTES=10

# ---------------------------------------------
# Storage Configuration
# ---------------------------------------------
FILESYSTEM_DISK=public

# ---------------------------------------------
# Logging Configuration
# ---------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=warning

# ---------------------------------------------
# Next.js Environment Variables (for customer app)
# ---------------------------------------------
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NODE_ENV=production

# ---------------------------------------------
# Vite Environment Variables (for frontend)
# ---------------------------------------------
VITE_API_BASE_URL=https://yourdomain.com/api

# ---------------------------------------------
# Security Notes
# ---------------------------------------------
# 1. Generate APP_KEY: docker compose exec backend php artisan key:generate
# 2. Generate strong DB passwords: openssl rand -base64 32
# 3. Generate HASHIDS_SALT: openssl rand -base64 32
# 4. For Gmail SMTP: Use App Password, not your regular password
# 5. Never commit this file with real secrets!
# ---------------------------------------------
