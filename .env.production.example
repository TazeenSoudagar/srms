# ============================================================================
# SRMS Production Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# cp .env.production.example .env

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_NAME=SRMS
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

# Generate with: docker run --rm composer:latest php artisan key:generate --show
APP_KEY=base64:YOUR_GENERATED_KEY_HERE

# ----------------------------------------------------------------------------
# Frontend URLs
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_CUSTOMER_URL=https://yourdomain.com
NEXT_PUBLIC_ENGINEER_URL=https://engineer.yourdomain.com

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=srms_production
DB_USERNAME=srms_user
DB_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ANOTHER_STRONG_PASSWORD

# ----------------------------------------------------------------------------
# Security - Hashids (CRITICAL: Keep consistent across deployments!)
# ----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
HASHIDS_SALT=YOUR_RANDOM_SALT_HERE_KEEP_SECRET_AND_CONSISTENT

# ----------------------------------------------------------------------------
# Cache & Session
# ----------------------------------------------------------------------------
CACHE_DRIVER=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.yourdomain.com

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ----------------------------------------------------------------------------
# Queue
# ----------------------------------------------------------------------------
QUEUE_CONNECTION=database

# ----------------------------------------------------------------------------
# Sanctum Authentication
# ----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com,engineer.yourdomain.com

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://engineer.yourdomain.com

# ----------------------------------------------------------------------------
# Mail Configuration (Production SMTP)
# ----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# OTP Settings (IMPORTANT: Set to false in production!)
# ----------------------------------------------------------------------------
ADMIN_BYPASS_OTP=false

# ----------------------------------------------------------------------------
# File Storage
# ----------------------------------------------------------------------------
FILESYSTEM_DISK=local
# For S3 (future):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_STACK=daily

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# ----------------------------------------------------------------------------
# Docker Build Args (for Next.js builds)
# ----------------------------------------------------------------------------
# These are used during docker build, not runtime
VITE_API_BASE_URL=https://api.yourdomain.com/api
