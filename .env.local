# ============================================================================
# SRMS Local Docker Development Environment
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_NAME=SRMS
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Generate this: php artisan key:generate
APP_KEY=

# ----------------------------------------------------------------------------
# Frontend URLs
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_CUSTOMER_URL=http://localhost
NEXT_PUBLIC_ENGINEER_URL=http://engineer.localhost

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=srms_backend
DB_USERNAME=srms_user
DB_PASSWORD=local_password_123
DB_ROOT_PASSWORD=root_password_123

# ----------------------------------------------------------------------------
# Security - Hashids
# ----------------------------------------------------------------------------
HASHIDS_SALT=local_development_salt_change_in_production

# ----------------------------------------------------------------------------
# Cache & Session
# ----------------------------------------------------------------------------
CACHE_DRIVER=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.localhost

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ----------------------------------------------------------------------------
# Queue
# ----------------------------------------------------------------------------
QUEUE_CONNECTION=database

# ----------------------------------------------------------------------------
# Sanctum Authentication
# ----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3001,engineer.localhost

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001,http://engineer.localhost

# ----------------------------------------------------------------------------
# Mail Configuration (Local - Mailtrap or Log)
# ----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# OTP Settings (Bypass for local development)
# ----------------------------------------------------------------------------
ADMIN_BYPASS_OTP=true

# ----------------------------------------------------------------------------
# File Storage
# ----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_STACK=single

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
BCRYPT_ROUNDS=10

# ----------------------------------------------------------------------------
# Docker Build Args
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost/api
