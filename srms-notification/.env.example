PORT=4000

# Must match srms-backend DB credentials exactly
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=srms
DB_USER=root
DB_PASSWORD=

# Must match srms-backend MAIL_* values
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=srms@test.in
MAIL_FROM_NAME=SRMS

# Shared secret — Laravel sends this in X-Service-Token header
SERVICE_TOKEN=srms-notification-secret
